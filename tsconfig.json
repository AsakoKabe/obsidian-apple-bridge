{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": ["ES6", "DOM"],
    "skipLibCheck": true,
    "paths": {
      "obsidian": ["./node_modules/obsidian/obsidian.d.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "src/__tests__/**", "src/__mocks__/**"]
}
