{
  "name": "obsidian-apple-bridge",
  "version": "0.2.1",
  "description": "Connect your Obsidian vault with Apple apps",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts --ignore-pattern 'src/__tests__/**' --ignore-pattern 'src/__mocks__/**'",
    "lint:fix": "eslint src --ext .ts --ignore-pattern 'src/__tests__/**' --ignore-pattern 'src/__mocks__/**' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "keywords": [
    "obsidian",
    "apple",
    "reminders",
    "calendar",
    "contacts",
    "notes"
  ],
  "author": "AsakoKabe",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^3.2.4",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "obsidian": "latest",
    "prettier": "^3.8.2",
    "tslib": "2.6.0",
    "typescript": "5.3.3",
    "vitest": "^3.2.4"
  }
}
