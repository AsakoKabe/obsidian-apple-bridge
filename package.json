{
  "name": "obsidian-apple-bridge",
  "version": "0.1.0",
  "description": "Connect your Obsidian vault with Apple apps",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "obsidian",
    "apple",
    "reminders",
    "calendar",
    "contacts",
    "notes"
  ],
  "author": "AsakoKabe",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "2.6.0",
    "typescript": "5.3.3",
    "vitest": "^3.2.4"
  }
}
